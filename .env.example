# ── Single deployment (Render / Railway / Fly.io / Heroku) ────────────────────
# Only these two are needed. Frontend is served by the same Express server.
JWT_SECRET=change-this-to-a-long-random-string
PORT=5000

# ── Split deployment only (frontend on Vercel, backend elsewhere) ─────────────
# Uncomment and set these if you deploy frontend and backend separately.
# FRONTEND_URL=https://your-app.vercel.app          ← set on backend host
# REACT_APP_BACKEND_URL=https://your-backend.fly.dev ← set in Vercel env vars
